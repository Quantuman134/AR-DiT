# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
.Python
pip-wheel-metadata/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Testing / coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# --- Editors / OS ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Jupyter ---
.ipynb_checkpoints/

# --- ML / experiment artefacts ---
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.bin
checkpoints/
runs/
logs/
wandb/
outputs/
samples/
results/
# `data/` holds both a source Python package (dataset adapters) AND the
# downloaded CIFAR-10 cache. Ignore everything under it by default, then
# whitelist the tracked source files.
data/*
!data/*.py
!data/**/*.py
datasets/

# --- Secrets (wandb token, API keys, etc.) ---
# Keep the folder itself tracked (via secrets/.gitkeep) so a fresh
# clone always has a canonical place to drop `wandb.token`, but never
# commit the credentials themselves.
secrets/*
!secrets/.gitkeep

# --- Reference papers / large binaries (keep out of repo) ---
*.pdf
